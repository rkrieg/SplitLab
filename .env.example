# ============================================================
# SplitLab Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- App Config ----
# The hostname of this app (used to detect custom client domains in middleware)
APP_HOSTNAME=splitlab.agency

# The public URL of this app (used for tracking snippet injection)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Storage ----
# Storage provider: 'supabase' (default) or 's3'
STORAGE_PROVIDER=supabase

# Supabase Storage bucket name for HTML pages
SUPABASE_STORAGE_BUCKET=pages

# AWS S3 (optional — only required if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ---- Admin Bootstrap ----
# Used to create the first admin user on first boot
BOOTSTRAP_ADMIN_EMAIL=admin@youragency.com
BOOTSTRAP_ADMIN_PASSWORD=changeme123!
BOOTSTRAP_ADMIN_NAME=Agency Admin
