# ============================================================
# SplitLab Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- App Config ----
# The hostname of this app (used to detect custom client domains in middleware)
APP_HOSTNAME=splitlab.agency

# The public URL of this app (used for tracking snippet injection)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Storage ----
# Storage provider: 'supabase' (default) or 's3'
STORAGE_PROVIDER=supabase

# Supabase Storage bucket name for HTML pages
SUPABASE_STORAGE_BUCKET=pages

# AWS S3 (optional — only required if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ---- Vercel Domain API ----
# Required for custom domain management
# Get your token from https://vercel.com/account/tokens
VERCEL_API_TOKEN=your-vercel-api-token
# Find in Vercel project settings > General > Project ID
VERCEL_PROJECT_ID=your-vercel-project-id

# ---- Email (Resend) ----
RESEND_API_KEY=re_...

# ---- Admin Bootstrap ----
# Used to create the first admin user on first boot
BOOTSTRAP_ADMIN_EMAIL=admin@youragency.com
BOOTSTRAP_ADMIN_PASSWORD=changeme123!
BOOTSTRAP_ADMIN_NAME=Agency Admin


#-------------------------------------------------------------------------------------#

# ---- AI page builder ----
# Which provider askAI() (src/lib/ai-client.ts) talks to. Default is
# "anthropic" — leave unset for normal production use. Set to anything else
# (e.g. "openai-compatible") to route through an OpenAI-compatible endpoint
# instead — ANY backend that speaks the OpenAI wire format works here:
# Gemini, Groq, Together, OpenRouter, OpenAI's own API, or a local model via
# Ollama/vLLM. Swapping providers is a .env change only; no code changes.
AI_PROVIDER=anthropic

# Required when AI_PROVIDER=anthropic (the default)
ANTHROPIC_API_KEY=sk-ant-...
# Optional — defaults to claude-sonnet-4-6 if unset
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required for every non-anthropic backend EXCEPT OpenAI's own API — each one
# lives at a different URL, and only the `openai` npm package's own default
# (https://api.openai.com/v1) is built in. Examples:
#   Local Ollama : http://localhost:11434/v1
#   Gemini       : https://generativelanguage.googleapis.com/v1beta/openai/
#   Groq         : https://api.groq.com/openai/v1
#   Together.ai  : https://api.together.ai/v1
# Leave blank only when using OpenAI's own API.
AI_BASE_URL=
# Local providers like Ollama ignore this — any non-empty string works.
# Every hosted provider (OpenAI's own API, Gemini, Groq, Together, OpenRouter, etc.) needs a real key.
AI_API_KEY=
# The exact model name as that provider expects it
# (e.g. "llama3.2:1b" for Ollama, "gemini-3.5-flash" for Gemini, "gpt-5" for OpenAI's own API)
AI_MODEL=
